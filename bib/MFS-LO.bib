@article{YE2025105093,
title = {LiDAR odometry method based on multi-scale fusion and semantic enhancement},
journal = {Robotics and Autonomous Systems},
volume = {194},
pages = {105093},
year = {2025},
issn = {0921-8890},
doi = {https://doi.org/10.1016/j.robot.2025.105093},
url = {https://www.sciencedirect.com/science/article/pii/S0921889025001903},
author = {Yibin Ye and Yang Ren and Yiming Fan and Yiyou Liang and Hui Zeng},
keywords = {Deep learning, LiDAR odometry, 3D point cloud, Pose estimation},
abstract = {In this paper, we propose an end-to-end deep learning-based LiDAR odometry framework addressing key challenges such as point cloud information loss, density variability, and dynamic scene uncertainty. By directly using raw point clouds, our method avoids dimensionality reduction loss and introduces a light-weight geometrically adaptive convolution to improve feature extraction based on local geometric structures. Additionally, a multi-scale fusion and semantic enhancement strategy is employed to incorporate semantic context and optimize pose estimation from coarse to fine. Experimental results on the KITTI dataset show that our approach is competitive with existing methods in accuracy and robustness.}
}